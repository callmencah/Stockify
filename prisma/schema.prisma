generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("STAFF") // ADMIN, MANAGER, STAFF, VIEWER
  isActive  Boolean  @default(true)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockTransactions StockTransaction[]
  purchaseOrders    PurchaseOrder[]
  salesOrders       SalesOrder[]
  stockOpnames      StockOpname[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  stockAdjustments  StockAdjustment[]
}

model Location {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  address   String?
  type      String   @default("WAREHOUSE") // WAREHOUSE, STORE, SUPPLIER, CUSTOMER
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itemLocations         ItemLocation[]
  stockTransactionsFrom StockTransaction[] @relation("FromLocation")
  stockTransactionsTo   StockTransaction[] @relation("ToLocation")
  purchaseOrders        PurchaseOrder[]
  salesOrders           SalesOrder[]
  stockOpnames          StockOpname[]
}

model Category {
  id          String     @id @default(cuid())
  name        String
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryParent")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  items Item[]

  @@index([parentId])
}

model Unit {
  id           String   @id @default(cuid())
  name         String
  abbreviation String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items Item[]
}

model Item {
  id           String   @id @default(cuid())
  sku          String   @unique
  barcode      String?  @unique
  name         String
  description  String?
  photo        String?
  buyPrice     Float    @default(0)
  sellPrice    Float    @default(0)
  minStock     Int      @default(0)
  reorderPoint Int      @default(0)
  categoryId   String?
  unitId       String?
  isActive     Boolean  @default(true)
  trackSerial  Boolean  @default(false)
  trackBatch   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category             Category?             @relation(fields: [categoryId], references: [id])
  unit                 Unit?                 @relation(fields: [unitId], references: [id])
  itemLocations        ItemLocation[]
  stockTransactions    StockTransaction[]
  purchaseOrderItems   PurchaseOrderItem[]
  salesOrderItems      SalesOrderItem[]
  serialNumbers        SerialNumber[]
  batches              Batch[]
  stockOpnameItems     StockOpnameItem[]
  stockAdjustmentItems StockAdjustmentItem[]

  @@index([categoryId])
  @@index([unitId])
}

model ItemLocation {
  id         String   @id @default(cuid())
  itemId     String
  locationId String
  quantity   Float    @default(0)
  updatedAt  DateTime @updatedAt

  item     Item     @relation(fields: [itemId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([itemId, locationId])
  @@index([locationId])
}

model SerialNumber {
  id        String   @id @default(cuid())
  itemId    String
  serial    String   @unique
  status    String   @default("AVAILABLE") // AVAILABLE, SOLD, DEFECTIVE, RETURNED
  batchId   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item  Item   @relation(fields: [itemId], references: [id])
  batch Batch? @relation(fields: [batchId], references: [id])

  @@index([itemId])
  @@index([batchId])
}

model Batch {
  id          String    @id @default(cuid())
  itemId      String
  batchNumber String
  expiryDate  DateTime?
  quantity    Float     @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  item          Item           @relation(fields: [itemId], references: [id])
  serialNumbers SerialNumber[]

  @@unique([itemId, batchNumber])
}

model StockTransaction {
  id             String   @id @default(cuid())
  type           String // PURCHASE, SALE, TRANSFER_IN, TRANSFER_OUT, ADJUSTMENT, RETURN_IN, RETURN_OUT, OPNAME
  itemId         String
  fromLocationId String?
  toLocationId   String?
  quantity       Float
  unitCost       Float?
  reference      String? // PO number, SO number, etc.
  notes          String?
  userId         String
  createdAt      DateTime @default(now())

  item         Item      @relation(fields: [itemId], references: [id])
  fromLocation Location? @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location? @relation("ToLocation", fields: [toLocationId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@index([itemId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([userId])
}

model Supplier {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  contact   String?
  email     String?
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model Customer {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  contact   String?
  email     String?
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesOrders SalesOrder[]
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  number       String    @unique
  supplierId   String?
  locationId   String
  status       String    @default("DRAFT") // DRAFT, SENT, PARTIAL, RECEIVED, CANCELLED
  orderDate    DateTime  @default(now())
  expectedDate DateTime?
  notes        String?
  userId       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier Supplier?           @relation(fields: [supplierId], references: [id])
  location Location            @relation(fields: [locationId], references: [id])
  user     User                @relation(fields: [userId], references: [id])
  items    PurchaseOrderItem[]

  @@index([supplierId])
  @@index([locationId])
  @@index([userId])
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  itemId          String
  quantity        Float
  receivedQty     Float   @default(0)
  unitCost        Float
  notes           String?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item          Item          @relation(fields: [itemId], references: [id])

  @@index([purchaseOrderId])
  @@index([itemId])
}

model SalesOrder {
  id         String   @id @default(cuid())
  number     String   @unique
  customerId String?
  locationId String
  status     String   @default("DRAFT") // DRAFT, CONFIRMED, SHIPPED, DELIVERED, CANCELLED
  orderDate  DateTime @default(now())
  notes      String?
  discount   Float    @default(0)
  tax        Float    @default(0)
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer?        @relation(fields: [customerId], references: [id])
  location Location         @relation(fields: [locationId], references: [id])
  user     User             @relation(fields: [userId], references: [id])
  items    SalesOrderItem[]

  @@index([customerId])
  @@index([locationId])
  @@index([userId])
}

model SalesOrderItem {
  id           String  @id @default(cuid())
  salesOrderId String
  itemId       String
  quantity     Float
  unitPrice    Float
  discount     Float   @default(0)
  notes        String?

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId], references: [id])

  @@index([salesOrderId])
  @@index([itemId])
}

model StockOpname {
  id         String    @id @default(cuid())
  number     String    @unique
  locationId String
  status     String    @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED, CANCELLED
  startDate  DateTime  @default(now())
  endDate    DateTime?
  notes      String?
  userId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  location Location          @relation(fields: [locationId], references: [id])
  user     User              @relation(fields: [userId], references: [id])
  items    StockOpnameItem[]

  @@index([locationId])
  @@index([userId])
}

model StockOpnameItem {
  id            String  @id @default(cuid())
  stockOpnameId String
  itemId        String
  systemQty     Float
  physicalQty   Float?
  difference    Float?
  notes         String?

  stockOpname StockOpname @relation(fields: [stockOpnameId], references: [id], onDelete: Cascade)
  item        Item        @relation(fields: [itemId], references: [id])

  @@index([stockOpnameId])
  @@index([itemId])
}

model StockAdjustment {
  id         String   @id @default(cuid())
  number     String   @unique
  locationId String?
  reason     String
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  notes      String?
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User                  @relation(fields: [userId], references: [id])
  items StockAdjustmentItem[]

  @@index([locationId])
  @@index([userId])
}

model StockAdjustmentItem {
  id                String  @id @default(cuid())
  stockAdjustmentId String
  itemId            String
  locationId        String
  quantity          Float // positive = add, negative = remove
  notes             String?

  stockAdjustment StockAdjustment @relation(fields: [stockAdjustmentId], references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId], references: [id])

  @@index([stockAdjustmentId])
  @@index([itemId])
  @@index([locationId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entity    String // Item, PurchaseOrder, etc.
  entityId  String?
  oldValue  String? // JSON string
  newValue  String? // JSON string
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // LOW_STOCK, PO_RECEIVED, SO_CONFIRMED, SYSTEM
  title     String
  message   String
  entityId  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
